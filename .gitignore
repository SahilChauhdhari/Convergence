# Dependency directories (CRITICAL: prevents ELF header errors)
# This ignores node_modules anywhere in the project
**/node_modules/
**/.env

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables (CRITICAL: keeps your secrets off GitHub)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Operating System files
.DS_Store
Thumbs.db

# Build/Dist folders (if using TypeScript or a bundler)
dist/
build/
out/

# SQLite databases (prevents uploading your local testing data)
*.db
*.sqlite
*.sqlite3

# IDE Specific files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
